# Secrets Cloudinary pour les Edge Functions (médias du projet).
#
# Copier ce fichier en `supabase/functions/.env` (ignoré par git) et renseigner
# les valeurs depuis le dashboard Cloudinary (Settings → API Keys).
#
#   - Développement local :
#       npx supabase functions serve --env-file ./supabase/functions/.env
#   - Production :
#       npx supabase secrets set --env-file ./supabase/functions/.env
#     (ou Dashboard → Edge Functions → Secrets)
#
# Le Cloud Name est public (il est aussi côté front dans src/environments) ;
# l'API Key et surtout l'API Secret ne doivent JAMAIS entrer dans le build
# Angular — ils restent exclusivement ici, côté serveur.

CLOUDINARY_CLOUD_NAME=ton-cloud-name
CLOUDINARY_API_KEY=xxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
